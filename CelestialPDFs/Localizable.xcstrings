    "vocabulary.empty.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select words while reading PDFs to automatically save them here"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在阅读 PDF 时选中单词查词，将自动记录到此处"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PDFを読みながら単語を選択すると、ここに自動保存されます"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "閱讀 PDF 時選取單詞就會自動儲存在這裡"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez des mots en lisant des PDF pour les enregistrer automatiquement ici"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie beim Lesen von PDFs Wörter aus, um sie hier automatisch zu speichern"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε λέξεις ενώ διαβάζετε PDF για να αποθηκευτούν αυτόματα εδώ"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona parole durante la lettura dei PDF per salvarle automaticamente qui"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecciona palabras mientras lees PDFs para guardarlas automáticamente aquí"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PDF를 읽는 동안 단어를 선택하면 여기 자동으로 저장됩니다"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выделяйте слова при чтении PDF — они автоматически сохранятся здесь"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione palavras enquanto lê PDFs para salvá-las automaticamente aqui"
          }
        }
      }
    },
